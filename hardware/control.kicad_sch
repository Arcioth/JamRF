	(text "THERMAL MONITORING\n+3V3 -> R_TH (10k fixed) -> midpoint -> TH1 (10k NTC) -> GND\nMidpoint to THERM_ADC -> G36 (ADC1_CH0, always available)\nR_ntc = R_TH * adc / (ADC_MAX - adc)\nAt 25C: ~1.65V  At 85C: ~2.7V (voltage rises with temp)"
		(exclude_from_sim no)
		(at 39.624 33.02 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left)
		)
		(uuid "b6000000-4001-0000-0000-000000000001")
	)
	(text "BIAS SEQUENCING (sense on IN_A-, ref on IN_A+)\nSense divider: +3V3 -> 100k -> 270k -> -5V\n  -5V present: midpoint ~1.06V (below ref)\n  -5V absent:  midpoint ~2.41V (above ref)\nReference: 3.3V * 82k/182k = 1.49V\nOUT_A high (via R_PU) when -5V OK -> BIAS_OK HIGH -> Q1 ON\nOUT_A low when -5V absent -> BIAS_OK LOW -> Q1 OFF (safe)"
		(exclude_from_sim no)
		(at 128.27 31.75 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left)
		)
		(uuid "b6000000-4002-0000-0000-000000000001")
	)
