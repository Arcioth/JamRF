	(text "BRANCH 1: 14.8V to 5V Buck Converter\nU2 D24V10F5, SHDN tied to +14V8 (always on)\nD1 TVS overvoltage clamp on 5V rail\nC_IN1/C_IN2 input decoupling"
		(exclude_from_sim no)
		(at 63.5 38.1 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left)
		)
		(uuid "b5003001-0000-0000-0000-000000000001")
	)
	(text "BRANCH 2: 14.8V to 10V Analog LDO\nU3 TPS7A4700, EN tied to +14V8 (always on)\nC_LDO_IN input, C_LDO_OUT output, C_NR noise/softstart"
		(exclude_from_sim no)
		(at 63.5 93.98 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left)
		)
		(uuid "b5003002-0000-0000-0000-000000000001")
	)
	(text "BRANCH 3: WiFi PA MOSFET Switch\nQ2 P-ch high-side switch, R_Q2_PU keeps OFF\nQ3 N-ch level shifter, RELAY_CTRL activates\nC1-C4 POSCAP bank on +14V8_WIFI rail\nR_SNUB+C_SNUB RC snubber damps POSCAP LC ringing\nC_BULK_IN hot-plug damping cap on battery input"
		(exclude_from_sim no)
		(at 165.1 76.2 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left)
		)
		(uuid "b5003003-0000-0000-0000-000000000001")
	)
	(text "BRANCH 4: GaN PA MOSFET Switch\nQ1 P-ch high-side switch, R_G1 keeps OFF\nQ_N1 N-ch level shifter, BIAS_OK activates"
		(exclude_from_sim no)
		(at 165.1 134.62 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left)
		)
		(uuid "b5003004-0000-0000-0000-000000000001")
	)
	(text "BRANCH 5: Charge Pump -5V\nU8 LM2776, 5V to -5V inverting\nEN controlled by BIAS_EN\nC_FLY flying cap, C_CP_OUT output filter\nC_CP_IN local VIN decoupling (required per datasheet)"
		(exclude_from_sim no)
		(at 228.6 38.1 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left)
		)
		(uuid "b5003005-0000-0000-0000-000000000001")
	)
	(text "Battery Input\nXT60 Connector\n14.8V 4S LiPo"
